---
import { site } from "../data/site";
import { path } from "../lib/paths";

const pathname = Astro.url.pathname;
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");

const links = [
  { href: path("/"), route: "/", label: "Home" },
  { href: path("/blog"), route: "/blog", label: "Blog" },
  { href: path("/games"), route: "/games", label: "Jogos" },
  { href: path("/about"), route: "/about", label: "Sobre" },
];

function isActive(route: string) {
  const current = pathname.replace(baseRoot, "") || "/";
  if (route === "/") return current === "/";
  return current === route || current.startsWith(`${route}/`);
}
---

<header class="border-b border-arcane/15 bg-night/70 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
    <a
      href={path("/")}
      class="font-display text-xl font-semibold tracking-tight text-ink transition-colors hover:text-arcane-bright sm:text-2xl"
    >
      {site.name}
    </a>
    <nav class="flex flex-wrap items-center justify-end gap-1 sm:gap-2" aria-label="Principal">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
              isActive(link.route)
                ? "bg-arcane/15 text-arcane-bright"
                : "text-ink-muted hover:bg-arcane/10 hover:text-ink",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
