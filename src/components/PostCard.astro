---
import { categories, type Category } from "../data/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
const label = categories[category as Category];

const dateLabel = pubDate.toLocaleDateString("pt-BR", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${post.id}`}
  class="group block border-b border-moss/15 py-5 transition-colors first:pt-0 last:border-0 hover:border-moss/30"
>
  <div class="flex flex-wrap items-center gap-2 text-xs font-medium tracking-wide uppercase">
    <span class="text-amber">{label}</span>
    <span class="text-ink-muted/40">·</span>
    <time class="text-ink-muted" datetime={pubDate.toISOString()}>{dateLabel}</time>
  </div>
  <h3
    class="font-display mt-2 text-xl font-semibold text-ink transition-colors group-hover:text-moss sm:text-2xl"
  >
    {title}
  </h3>
  <p class="mt-1.5 max-w-2xl text-sm text-ink-muted sm:text-base">{description}</p>
  <span
    class="mt-3 inline-block text-sm font-medium text-moss opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100"
  >
    Ler mais →
  </span>
</a>
