---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";
import GameCard from "../components/GameCard.astro";
import { site } from "../data/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const games = (await getCollection("games"))
  .filter((g) => g.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const latestPosts = posts.slice(0, 3);
---

<BaseLayout>
  <Header slot="header" />

  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-5xl px-5 pt-16 pb-20 sm:px-8 sm:pt-24 sm:pb-28">
      <p class="animate-fade-up font-display text-5xl font-bold tracking-tight text-ink sm:text-7xl">
        {site.name}
      </p>
      <p
        class="animate-fade-up-delay mt-4 max-w-xl text-lg text-ink-muted sm:text-xl"
      >
        {site.tagline}
      </p>
      <div class="animate-fade-up-delay-2 mt-8 flex flex-wrap gap-3">
        <a
          href="/games"
          class="rounded-md bg-moss px-5 py-2.5 text-sm font-semibold text-paper transition hover:bg-moss-bright"
        >
          Ver jogos
        </a>
        <a
          href="/blog"
          class="rounded-md border border-moss/30 bg-paper/50 px-5 py-2.5 text-sm font-semibold text-moss transition hover:border-moss hover:bg-moss/5"
        >
          Ler o blog
        </a>
      </div>
    </div>
  </section>

  {
    games.length > 0 && (
      <section class="border-t border-moss/10 bg-paper/40">
        <div class="mx-auto max-w-5xl px-5 py-14 sm:px-8 sm:py-16">
          <div class="mb-8 flex items-end justify-between gap-4">
            <div>
              <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">Jogos</h2>
              <p class="mt-1 text-sm text-ink-muted">O que estamos fazendo agora.</p>
            </div>
            <a href="/games" class="text-sm font-medium text-moss hover:text-moss-bright">
              Catálogo →
            </a>
          </div>
          <div class="grid gap-8 sm:grid-cols-2">
            {games.map((game) => (
              <GameCard game={game} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="border-t border-moss/10">
    <div class="mx-auto max-w-5xl px-5 py-14 sm:px-8 sm:py-16">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">Últimas do blog</h2>
          <p class="mt-1 text-sm text-ink-muted">Notícias, patches e divulgações.</p>
        </div>
        <a href="/blog" class="text-sm font-medium text-moss hover:text-moss-bright">
          Ver tudo →
        </a>
      </div>
      <div>
        {latestPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
